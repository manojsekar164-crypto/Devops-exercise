{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBReadWriteAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:ap-south-1:123456789012:table/customer-data"
    }
  ]
}
